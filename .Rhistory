test_scores[test_scores == 75]
# Multiple conditions
test_scores[test_scores > 75 & test_scores > 90]
test_scores[test_scores > 75 | test_scores > 90]
test_scores[test_scores > 75 | test_scores > 90]
test_scores[test_scores <= 60 & test_scores > 90]
test_scores[test_scores <= 60 | test_scores > 90]
